{
  "_version": "1.84.0",
  "sap.app": {
    "id": "finn.invoice.finninvoicetracking",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "${project.version}"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.23.0",
      "toolsId": "24b78526-28db-47dc-98fb-802094f59c8f"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/z_ui_invoicetracking/srvd/sap/z_ui_invoicetracking/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.01"
        }
      }
    },
    "ach": "FE-TR"
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "${sap.ui5.dist.version}",
      "libs": {
        "sap.m": {
          "lazy": false
        },
        "sap.ui.core": {
          "lazy": false
        },
        "sap.fe.templates": {
          "lazy": false
        }
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "finn.invoice.finninvoicetracking.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "InvoiceHeaderList",
          "target": "InvoiceHeaderList"
        },
        {
          "pattern": "InvoiceHeader({key}):?query:",
          "name": "InvoiceHeaderObjectPage",
          "target": "InvoiceHeaderObjectPage"
        },
        {
          "pattern": "InvoiceHeader({key})/_Items({key2}):?query:",
          "name": "InvoiceItemsObjectPage",
          "target": "InvoiceItemsObjectPage"
        }
      ],
      "targets": {
        "InvoiceHeaderList": {
          "type": "Component",
          "id": "InvoiceHeaderList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/InvoiceHeader",
              "variantManagement": "Page",
              "navigation": {
                "InvoiceHeader": {
                  "detail": {
                    "route": "InvoiceHeaderObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Multi",
                    "creationMode": {
                      "name": "NewPage"
                    }
                  },
                  "actions": {
                    "ListReportExt": {
                      "press": "finn.invoice.finninvoicetracking.ext.controller.ListReportExt.onClickUploadEdit",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "Create from PDF"
                    }
                  }
                }
              }
            }
          }
        },
        "InvoiceHeaderObjectPage": {
          "type": "Component",
          "id": "InvoiceHeaderObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": true,
              "contextPath": "/InvoiceHeader",
              "enhanceI18n": "i18n/i18n.properties",
              "content": {
                "header": {
                  "visible": true
                }
              },
              "navigation": {
                "_Items": {
                  "detail": {
                    "route": "InvoiceItemsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.FieldGroup#GeneratedGroup": {
                  "useFormContainerLabels": true
                }
              }
            }
          }
        },
        "InvoiceItemsObjectPage": {
          "type": "Component",
          "id": "InvoiceItemsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/InvoiceHeader/_Items"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [
      "FIORITR"
    ],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
