# =====================================================
# FINN Invoice Tracking - Project .gitignore
# =====================================================

# Folders to exclude completely
API_Design/
Back_UP_Files/

# =====================================================
# Fiori/UI5 Application
# =====================================================

# Dependencies
node_modules/
package-lock.json

# Build outputs
dist/
resources/
.scp/

# SAP Cloud Platform / BTP
mta_archives/
mta-*/
Makefile*.mta
.*_mta_build_tmp
archive.zip

# TypeScript build
*.tsbuild
.tsbuild

# =====================================================
# Sensitive Configuration Files
# =====================================================

# Environment variables
.env
.env.local
.env.*.local
*.env

# UI5 YAML files with system URLs (SENSITIVE)
ui5.yaml
ui5-local.yaml
ui5-ci.yaml
ui5-mock.yaml

# Keep template versions only (if you want to share structure)
# !ui5.yaml.template
# !ui5-local.yaml.template

# SAP destinations and credentials
default-env.json
*-credentials.json
.pipeline/config.yml

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.cert

# =====================================================
# IDE / Editor
# =====================================================

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IntelliJ / WebStorm / Eclipse
.idea/
*.iml
*.iws
.project
.classpath
.settings/
.metadata/

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# =====================================================
# Operating System
# =====================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*
.nfs*

# =====================================================
# Logs and Temporary Files
# =====================================================

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage and test reports
coverage/
*.lcov
.nyc_output/
test-results/
junit.xml

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup
*.old
*.orig

# =====================================================
# SAP Specific
# =====================================================

# ABAP Development Tools (ADT)
.adtcore/
.adt/

# SAP Web IDE
.che/
.projects/

# SAP Business Application Studio
.theia/

# =====================================================
# Optional: Keep Structure but Ignore Content
# =====================================================

# If you want to keep folder structure but ignore specific files
# API_Design/**
# !API_Design/.gitkeep
# Back_UP_Files/**
# !Back_UP_Files/.gitkeep

# =====================================================
# Project Specific
# =====================================================

# Ignore compiled/generated files
*.class
*.jar
*.war

# Local development databases (if any)
*.db
*.sqlite
*.sqlite3

# Test data generators (optional - uncomment if you want to exclude)
# ZFINN_GENERATE_TEST_DATA.abap

# =====================================================
# Security Best Practices
# =====================================================

# Never commit these patterns
*password*
*secret*
*token*
*apikey*
*api-key*
*credentials*
*.credential

# Exception: Allow documentation files about secrets
!*password*.md
!*secret*.md
!*credentials*.md
